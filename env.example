# ─────────────────────────────────────────────────────────────
# TechAssist — fichier de configuration "env"
# Copier ce fichier en "env" (sans extension) à la racine du projet
# et remplir les valeurs.  NE JAMAIS committer le vrai fichier "env".
# ─────────────────────────────────────────────────────────────

# Clé secrète Django (générer une longue chaîne aléatoire, >= 50 caractères)
SECRET_KEY=changez-moi-par-une-longue-cle-aleatoire

DEBUG=True

# ── Base de données ───────────────────────────────────────────
# Laisser DB_ENGINE vide (ou absent)  → SQLite local (db.sqlite3), rien à installer.
# Mettre DB_ENGINE=postgresql          → PostgreSQL (renseigner les champs ci-dessous).
DB_ENGINE=
DB_NAME=techassist_db
DB_USER=postgres
DB_PASSWORD=motdepasse
DB_HOST=localhost
DB_PORT=5432

# ── Clé API Grok (uniquement pour le pipeline de scraping/labeling) ──
# Optionnel : nécessaire seulement pour relabelliser le dataset (scraping/).
GROQ_API_KEY=
