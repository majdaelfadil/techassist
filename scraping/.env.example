# ============================================================
# Grok API (xAI) — required for the labeling pipeline
# ============================================================
GROK_API_KEY=your_grok_api_key_here
GROK_MODEL=grok-3-mini
GROK_BASE_URL=https://api.x.ai/v1
GROK_TIMEOUT_MS=30000

# ============================================================
# Optional API credentials
# ============================================================
# Stack Exchange API Key (optional — raises rate limit from 300 to 10k req/day)
STACK_EXCHANGE_API_KEY=your_stack_exchange_api_key_here

# Reddit API credentials (optional — raises rate limits)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=ITDatasetScraper/1.0

# ============================================================
# Scraping configuration
# ============================================================
MAX_INCIDENTS_PER_SOURCE=10000
SCRAPER_RATE_LIMIT_MS=1500
SCRAPER_MAX_RETRIES=3
# Number of parallel Reddit search workers (5 = ~5x faster, 10 = ~8x faster)
SCRAPER_CONCURRENCY=5
HEADLESS=true

# ============================================================
# Pipeline quality thresholds
# ============================================================
MIN_BODY_LENGTH=50
DEDUP_SIMILARITY_THRESHOLD=0.92

# Minimum confidence for AI-generated field values (0.0–1.0)
CONFIDENCE_THRESHOLD=0.60

# Minimum resolution score for an incident to be included (0–10)
RESOLUTION_SCORE_THRESHOLD=1

# ============================================================
# GPU / Embedding acceleration
# ============================================================
# Set USE_GPU=false to force CPU-only embeddings
USE_GPU=true
# Batch size for embedding generation (64 with GPU, 32 if CPU-only)
EMBED_BATCH_SIZE=64

# ============================================================
# Labeling
# ============================================================
LABEL_BATCH_SIZE=5
# Number of parallel Grok API calls (5 = ~5x faster labeling)
LABEL_CONCURRENCY=5
LABEL_MAX_RETRIES=3

# ============================================================
# Dataset split ratios (must sum to 1.0)
# ============================================================
TRAIN_SPLIT=0.80
VALID_SPLIT=0.10
TEST_SPLIT=0.10

# ============================================================
# Data directories
# ============================================================
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed
OUTPUT_DATA_DIR=./data/output
KNOWLEDGE_DIR=./data/knowledge
